# Supabase project settings (Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Must match the admin email hardcoded in public.is_admin() in
# supabase/migrations/20260716170851_init_schema.sql — keep both in sync.
ADMIN_EMAIL=hyeongjin326@gmail.com

# Optional. Base URL used for auth redirect (magic link / OAuth) callbacks.
# If unset, falls back to window.location.origin at call time, which is
# fine for local dev but should be set explicitly in production
# (https://blog.devjinlab.com) — also make sure this exact URL + "/auth/callback"
# is added to the Supabase project's Auth > URL Configuration > Redirect URLs
# allow-list, or GoTrue will silently fall back to its own configured Site URL.
NEXT_PUBLIC_SITE_URL=
